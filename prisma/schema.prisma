generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================================
// CORE: Users, Organizations, Memberships
// ============================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  isSuperAdmin   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  memberships    Membership[]
  createdContent Content[]
  assignedLeads  Lead[]         @relation("AssignedTo")
  activityLogs   ActivityLog[]
  notifications  Notification[]
  comments       Comment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  logo             String?
  domain           String?  @unique
  industry         String?
  timezone         String   @default("UTC")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  plan             PlanType  @default(FREE)
  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique
  planExpiresAt    DateTime?

  memberships      Membership[]
  socialAccounts   SocialAccount[]
  campaigns        Campaign[]
  content          Content[]
  adsCampaigns     AdsCampaign[]
  leads            Lead[]
  contacts         Contact[]
  emailCampaigns   EmailCampaign[]
  emailTemplates   EmailTemplate[]
  emailSubscribers EmailSubscriber[]
  keywords         Keyword[]
  seoAudits        SeoAudit[]
  reports          Report[]
  activityLogs     ActivityLog[]
  notifications    Notification[]
  leadForms        LeadForm[]
  contentTemplates ContentTemplate[]
  tags             Tag[]

  @@map("organizations")
}

model Membership {
  id             String     @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole @default(MEMBER)
  isActive       Boolean    @default(true)
  joinedAt       DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

enum MemberRole {
  ADMIN
  MANAGER
  MEMBER
}

enum PlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ============================================================
// SOCIAL
// ============================================================

model SocialAccount {
  id                String         @id @default(cuid())
  organizationId    String
  platform          SocialPlatform
  platformAccountId String
  accountName       String
  accessToken       String         @db.Text
  refreshToken      String?        @db.Text
  tokenExpiresAt    DateTime?
  isActive          Boolean        @default(true)
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  posts        ContentPost[]

  @@unique([organizationId, platform, platformAccountId])
  @@index([organizationId])
  @@map("social_accounts")
}

model SocialMention {
  id              String         @id @default(cuid())
  organizationId  String
  platform        SocialPlatform
  authorName      String?
  authorHandle    String?
  content         String         @db.Text
  url             String?
  sentiment       Sentiment?
  sentimentScore  Float?
  isCompetitor    Boolean        @default(false)
  matchedKeyword  String?
  engagementCount Int            @default(0)
  reachEstimate   Int?
  mentionedAt     DateTime
  createdAt       DateTime       @default(now())

  @@index([organizationId, mentionedAt])
  @@index([organizationId, sentiment])
  @@map("social_mentions")
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  PINTEREST
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

// ============================================================
// CONTENT
// ============================================================

model Content {
  id             String        @id @default(cuid())
  organizationId String
  title          String
  body           String        @db.Text
  contentType    ContentType
  status         ContentStatus @default(DRAFT)
  tone           String?
  language       String        @default("en")
  aiGenerated    Boolean       @default(false)
  aiPrompt       String?       @db.Text
  seoScore       Int?
  createdById    String
  approvedById   String?
  scheduledAt    DateTime?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User          @relation(fields: [createdById], references: [id])
  posts        ContentPost[]
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  campaignId   String?
  tags         Tag[]

  @@index([organizationId, status])
  @@index([organizationId, contentType])
  @@index([organizationId, scheduledAt])
  @@map("content")
}

model ContentPost {
  id              String     @id @default(cuid())
  contentId       String
  socialAccountId String
  platformPostId  String?
  status          PostStatus @default(PENDING)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  metrics         Json?
  errorMessage    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  content       Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id])

  @@index([contentId])
  @@map("content_posts")
}

model ContentTemplate {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  description    String?
  contentType    ContentType
  body           String      @db.Text
  variables      Json?
  isGlobal       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("content_templates")
}

enum ContentType {
  SOCIAL_POST
  BLOG_POST
  AD_COPY
  EMAIL
  LANDING_PAGE
  VIDEO_SCRIPT
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum PostStatus {
  PENDING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

// ============================================================
// CAMPAIGNS
// ============================================================

model Campaign {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  description    String?          @db.Text
  status         CampaignStatus   @default(DRAFT)
  type           CampaignType
  startDate      DateTime?
  endDate        DateTime?
  budget         Decimal?         @db.Decimal(12, 2)
  spentAmount    Decimal          @default(0) @db.Decimal(12, 2)
  goalType       String?
  goalTarget     Int?
  goalCurrent    Int              @default(0)
  channels       SocialPlatform[]
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  content        Content[]
  adsCampaigns   AdsCampaign[]
  emailCampaigns EmailCampaign[]
  analytics      CampaignAnalytics[]

  @@index([organizationId, status])
  @@map("campaigns")
}

model CampaignAnalytics {
  id          String   @id @default(cuid())
  campaignId  String
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  engagements Int      @default(0)
  reach       Int      @default(0)
  metadata    Json?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId, date])
  @@map("campaign_analytics")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignType {
  BRAND_AWARENESS
  LEAD_GENERATION
  SALES
  ENGAGEMENT
  PRODUCT_LAUNCH
  EVENT
  CUSTOM
}

// ============================================================
// ADS
// ============================================================

model AdsCampaign {
  id                 String            @id @default(cuid())
  organizationId     String
  campaignId         String?
  name               String
  platform           SocialPlatform
  platformCampaignId String?
  status             AdsCampaignStatus @default(DRAFT)
  objective          String
  dailyBudget        Decimal?          @db.Decimal(12, 2)
  totalBudget        Decimal?          @db.Decimal(12, 2)
  startDate          DateTime?
  endDate            DateTime?
  targetAudience     Json?
  bidStrategy        String?
  creativeAssets     Json?
  abTestConfig       Json?
  performanceData    Json?
  aiSuggestions      Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id])
  adSets       AdsSet[]

  @@index([organizationId, status])
  @@map("ads_campaigns")
}

model AdsSet {
  id             String   @id @default(cuid())
  adsCampaignId  String
  name           String
  targetAudience Json
  budget         Decimal? @db.Decimal(12, 2)
  bidAmount      Decimal? @db.Decimal(12, 2)
  status         String   @default("ACTIVE")
  metrics        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  adsCampaign AdsCampaign @relation(fields: [adsCampaignId], references: [id], onDelete: Cascade)

  @@map("ads_sets")
}

enum AdsCampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

// ============================================================
// LEADS & CRM
// ============================================================

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  contactId      String?
  source         String?
  sourceDetail   String?
  status         LeadStatus @default(NEW)
  score          Int        @default(0)
  scoreFactors   Json?
  assignedToId   String?
  pipelineStage  String     @default("new")
  estimatedValue Decimal?   @db.Decimal(12, 2)
  convertedAt    DateTime?
  lastActivityAt DateTime?
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?       @relation(fields: [contactId], references: [id])
  assignedTo   User?          @relation("AssignedTo", fields: [assignedToId], references: [id])
  activities   LeadActivity[]
  tags         Tag[]

  @@index([organizationId, status])
  @@index([organizationId, score])
  @@index([organizationId, pipelineStage])
  @@map("leads")
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  company        String?
  jobTitle       String?
  avatar         String?
  socialProfiles Json?
  customFields   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads           Lead[]
  emailSubscriber EmailSubscriber?

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("contacts")
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  description String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

model LeadForm {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  fields          Json
  style           Json?
  thankYouMessage String?
  redirectUrl     String?
  isActive        Boolean  @default(true)
  submissions     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("lead_forms")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  UNQUALIFIED
}

// ============================================================
// EMAIL MARKETING
// ============================================================

model EmailCampaign {
  id                String              @id @default(cuid())
  organizationId    String
  campaignId        String?
  name              String
  subject           String
  previewText       String?
  htmlContent       String              @db.Text
  textContent       String?             @db.Text
  templateId        String?
  status            EmailCampaignStatus @default(DRAFT)
  senderName        String?
  senderEmail       String?
  replyTo           String?
  scheduledAt       DateTime?
  sentAt            DateTime?
  totalSent         Int                 @default(0)
  totalOpened       Int                 @default(0)
  totalClicked      Int                 @default(0)
  totalBounced      Int                 @default(0)
  totalUnsubscribed Int                 @default(0)
  abTestConfig      Json?
  automationType    String?
  automationConfig  Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign?      @relation(fields: [campaignId], references: [id])
  template     EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([organizationId, status])
  @@map("email_campaigns")
}

model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  category       String?
  htmlContent    String   @db.Text
  thumbnail      String?
  isGlobal       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailCampaigns EmailCampaign[]

  @@index([organizationId])
  @@map("email_templates")
}

model EmailSubscriber {
  id             String           @id @default(cuid())
  organizationId String
  contactId      String?          @unique
  email          String
  firstName      String?
  lastName       String?
  status         SubscriberStatus @default(ACTIVE)
  subscribedAt   DateTime         @default(now())
  unsubscribedAt DateTime?
  metadata       Json?
  tags           Tag[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id])

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@map("email_subscribers")
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

// ============================================================
// SEO
// ============================================================

model Keyword {
  id             String    @id @default(cuid())
  organizationId String
  keyword        String
  searchVolume   Int?
  difficulty     Int?
  currentRank    Int?
  previousRank   Int?
  targetUrl      String?
  isTracking     Boolean   @default(true)
  lastChecked    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rankHistory  KeywordRankHistory[]

  @@unique([organizationId, keyword])
  @@index([organizationId])
  @@map("keywords")
}

model KeywordRankHistory {
  id        String   @id @default(cuid())
  keywordId String
  rank      Int?
  url       String?
  checkedAt DateTime @default(now())

  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@index([keywordId, checkedAt])
  @@map("keyword_rank_history")
}

model SeoAudit {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  score          Int?
  issues         Json
  suggestions    Json?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("seo_audits")
}

// ============================================================
// REPORTS
// ============================================================

model Report {
  id              String     @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  type            ReportType
  config          Json
  scheduleConfig  Json?
  isTemplate      Boolean    @default(false)
  whiteLabel      Json?
  lastGeneratedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("reports")
}

enum ReportType {
  CAMPAIGN
  SOCIAL
  ADS
  EMAIL
  SEO
  LEADS
  CUSTOM
  OVERVIEW
}

// ============================================================
// SHARED
// ============================================================

model Tag {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  color          String?

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  content          Content[]
  leads            Lead[]
  emailSubscribers EmailSubscriber[]

  @@unique([organizationId, name])
  @@map("tags")
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  type           String
  title          String
  message        String
  isRead         Boolean  @default(false)
  actionUrl      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([organizationId])
  @@map("notifications")
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@map("comments")
}
